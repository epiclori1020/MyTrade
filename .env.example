# ============================================================
# MyTrade — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git!
# ============================================================

# --- LLM (Anthropic API — NOT your Max subscription!) ---
# Get this from https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# --- Database (Supabase) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # Backend only! Never in frontend!

# --- Data Providers ---
FINNHUB_API_KEY=
ALPHA_VANTAGE_API_KEY=

# --- Broker (Alpaca) ---
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets   # Paper trading URL
ALPACA_PAPER_MODE=true              # MUST be true in Stufe 1!

# --- Auth ---
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# --- Budget Caps (3-Tier Model-Mix) ---
MONTHLY_OPUS_BUDGET_USD=30          # Heavy tier (Devil's Advocate + Synthesizer)
MONTHLY_SONNET_BUDGET_USD=20        # Standard tier (Analyse-Agents)
MONTHLY_HAIKU_BUDGET_USD=5          # Light tier (Extraction + Verification)
MONTHLY_TOTAL_API_BUDGET_USD=55     # Hard cap — no LLM calls beyond this
