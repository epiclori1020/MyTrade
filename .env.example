# ============================================================
# MyTrade — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git!
# ============================================================

# --- LLM ---
ANTHROPIC_API_KEY=

# --- Database (Supabase) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # Backend only! Never in frontend!

# --- Data Providers ---
FINNHUB_API_KEY=
ALPHA_VANTAGE_API_KEY=

# --- Broker (Alpaca) ---
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets   # Paper trading URL
ALPACA_PAPER_MODE=true              # MUST be true in Stufe 1!

# --- Auth ---
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# --- Budget Caps ---
MONTHLY_OPUS_BUDGET_USD=100
MONTHLY_SONNET_BUDGET_USD=20
