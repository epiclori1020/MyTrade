# ============================================================
# MyTrade — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git!
# ============================================================

# --- LLM (Anthropic API — NOT your Max subscription!) ---
# Get this from https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# --- Database (Supabase) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # Backend only! Never in frontend!

# --- Data Providers ---
FINNHUB_API_KEY=
ALPHA_VANTAGE_API_KEY=

# --- Broker (Alpaca) ---
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER_MODE=true              # MUST be true in Stufe 1!

# --- Admin ---
ADMIN_USER_IDS=                     # Comma-separated UUIDs for kill-switch admin access

# --- Frontend (NEXT_PUBLIC_* are exposed to the browser) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- App Config (optional) ---
# CORS_ORIGINS=http://localhost:3000
# ENVIRONMENT=development
# LOG_LEVEL=INFO
