# MyTrade Backend — Environment Variables
# Copy these values into ../.env (project root). Never commit .env files.
# The backend reads from the root .env via pydantic-settings (env_file="../.env").

# --- Supabase (Required) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# --- LLM ---
ANTHROPIC_API_KEY=

# --- Data Providers ---
FINNHUB_API_KEY=
ALPHA_VANTAGE_API_KEY=

# --- Broker (Stufe 1: Paper Trading ONLY) ---
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER_MODE=true

# --- App Config ---
CORS_ORIGINS=http://localhost:3000
ENVIRONMENT=development
LOG_LEVEL=INFO
